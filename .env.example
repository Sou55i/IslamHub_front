# ==========================================
# Configuration du mode de données
# ==========================================

# Mode de données: 'supabase' | 'express' | 'local'
# - supabase: Connexion directe à Supabase (recommandé, léger)
# - express:  Via le backend Express (si Supabase saturé)
# - local:    Données JSON locales (fallback)
# Si non défini, auto-détection selon les credentials disponibles
VITE_DATA_SOURCE=supabase

# ==========================================
# Configuration Supabase (mode supabase)
# ==========================================

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-clé-anon-publique

# ==========================================
# Configuration Backend Express (mode express)
# ==========================================

VITE_API_URL=http://localhost:3000
